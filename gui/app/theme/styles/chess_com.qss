QMainWindow {
    background-color: #262522;
}

QWidget {
    background-color: #312e2b;
    color: #ffffff;
}

QLabel {
    color: #ffffff;
    background: transparent;
}

QPushButton {
    background-color: #6ba64c;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 6px;
}

QPushButton:hover {
    background-color: #7ab857;
}

QLineEdit,
QTextEdit,
QPlainTextEdit {
    background-color: #3d3935;
    border: 1px solid #555;
    border-radius: 6px;
    padding: 4px;
}

#homePage {
    background-color: #312e2b;
}

#card {
    background-color: #3d3935;
    border-radius: 12px;
}

QLabel[status="searching"] {
    color: #4CAF50;
    font-weight: bold;
}
QLabel[status="idle"] {
    color: #2196F3;
    font-weight: bold;
}
QLabel[status="connecting"] {
    color: #FF9800;
    font-weight: bold;
}
QLabel[status="disconnected"] {
    color: #9E9E9E;
    font-weight: bold;
}

#controlPanel, #evaluationPanel {
    background-color: #262522;
    border: 1px solid #3d3935;
    border-radius: 10px;
}

#pvTextArea {
    background-color: #1a1917;
    color: #e5e5e5;
    border: 1px solid #555;
    border-radius: 6px;
    font-family: "Courier New", monospace;
    font-size: 11px;
}

#largeScoreLabel {
    color: #ffffff;
}

#activeSideLabel {
    color: #959595;
}

#telemetryVal {
    color: #81b64c;
    font-weight: bold;
}

#scrollControl, #scrollEval, #scrollControl > QWidget, #scrollEval > QWidget {
    background: transparent;
    background-color: transparent;
    border: none;
}

#sidebarSplitter::handle, #mainSplitter::handle {
    background-color: #3d3935;
}