QMainWindow {
    background-color: #262421;
}

QWidget {
    background-color: #312e2b;
    color: #e5e5e5;
}

QLabel {
    color: #e5e5e5;
    background: transparent;
}

QPushButton {
    background-color: #3d3935;
    border: 1px solid #4f4a46;
    border-radius: 6px;
    padding: 6px;
}

QPushButton:hover {
    background-color: #4a4540;
}

QLineEdit,
QTextEdit,
QPlainTextEdit {
    background-color: #3d3935;
    border: 1px solid #56514d;
    border-radius: 6px;
    padding: 4px;
}

#homePage {
    background-color: #312e2b;
}

#card {
    background-color: #3d3935;
    border-radius: 10px;
}

QLabel[status="searching"] {
    color: #4CAF50;
    font-weight: bold;
}
QLabel[status="idle"] {
    color: #2196F3;
    font-weight: bold;
}
QLabel[status="connecting"] {
    color: #FF9800;
    font-weight: bold;
}
QLabel[status="disconnected"] {
    color: #9E9E9E;
    font-weight: bold;
}

#controlPanel, #evaluationPanel, #moveHistoryPanel {
    background-color: #262421;
    border: 1px solid #3d3935;
    border-radius: 8px;
}

#pvTextArea {
    background-color: #161512;
    color: #bababa;
    border: 1px solid #4f4a46;
    border-radius: 6px;
    font-family: "Courier New", monospace;
    font-size: 11px;
}

#largeScoreLabel {
    color: #ffffff;
}

#activeSideLabel {
    color: #9e9e9e;
}

#telemetryVal {
    color: #ffd54f;
    font-weight: bold;
}

#scrollControl, #scrollEval, #scrollHistory, #scrollControl > QWidget, #scrollEval > QWidget, #scrollHistory > QWidget {
    background: transparent;
    background-color: transparent;
    border: none;
}

#sidebarSplitter::handle, #mainSplitter::handle {
    background-color: #3d3935;
}

#moveListTable {
    background-color: transparent;
    border: none;
    gridline-color: transparent;
}

#moveListTable::item {
    padding: 4px;
    border-radius: 3px;
}

#moveListTable::item:selected {
    background-color: #3d3935;
    color: #ffd54f;
    font-weight: bold;
}